# ===========================================
# 应用配置
# ===========================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ===========================================
# 数据库配置 (PostgreSQL)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_DATABASE=lifeline_ai

# ===========================================
# Redis配置
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# JWT配置 (用于后续认证模块)
# ===========================================
JWT_SECRET=your_jwt_secret_key_here_at_least_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# ClickHouse配置 (用于时序数据)
# ===========================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=lifeline_ai_telemetry

# ===========================================
# MQTT配置 (用于设备通信)
# ===========================================
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ===========================================
# EMQX配置
# ===========================================
EMQX_API_URL=http://localhost:8081
EMQX_API_KEY=
EMQX_API_SECRET=

# ===========================================
# 邮件配置 (用于通知)
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@lifeline-ai.com

# ===========================================
# 对象存储配置 (华为云OBS)
# ===========================================
OBS_ACCESS_KEY=
OBS_SECRET_KEY=
OBS_BUCKET=
OBS_ENDPOINT=

# ===========================================
# 安全配置
# ===========================================
# CORS允许的域名，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API Key前缀
API_KEY_PREFIX=lk_live_
